# -----------------------------------------------------------------------
# Booking Project – environment variables
# Copy this file to .env in the project root (next to docker-compose.yml)
# and fill in the required values.
# -----------------------------------------------------------------------

# --- Database (PostgreSQL) -------------------------------------------
POSTGRES_PASSWORD=change_me_to_a_strong_password
# POSTGRES_USER=booking          # default: booking
# POSTGRES_DB=booking            # default: booking

# --- Domain (used by Traefik for TLS routing) ------------------------
DOMAIN=booking.yourdomain.com

# --- JWT secrets (generate with: openssl rand -hex 64) ---------------
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string

# --- Admin account (created automatically on first startup) ----------
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe123!

# --- Public URLs (must match the domain above) -----------------------
FRONTEND_URL=https://booking.yourdomain.com
CORS_ORIGIN=https://booking.yourdomain.com

# --- Timezone (optional, default UTC) --------------------------------
# TZ=Europe/Copenhagen

# --- SMTP (optional – can also be configured in the admin Settings UI)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@yourdomain.com

# --- Traefik (optional overrides) ------------------------------------
# TRAEFIK_PING_URL=http://traefik:8080/ping
# TRAEFIK_PING_RETRIES=10
# TRAEFIK_PING_DELAY_SECONDS=3
