# Traefik
USE_INTERNAL_TRAEFIK=true
# Network name used to expose services to Traefik. When reusing an external
# proxy stack, set this to the shared network that Traefik is attached to.
TRAEFIK_NETWORK_NAME=booking-project-proxy
# Set to true when the network already exists (external Traefik); false lets
# docker compose manage the lifecycle for the built-in Traefik stack.
TRAEFIK_NETWORK_IS_EXTERNAL=false
# Health endpoint Traefik must expose. Adjust when using a shared stack with a
# different service name or port.
TRAEFIK_PING_URL=http://proxy:8080/ping
# Optional: override health-check behaviour when USE_INTERNAL_TRAEFIK=false
#TRAEFIK_PING_RETRIES=5
#TRAEFIK_PING_DELAY_SECONDS=2
#TRAEFIK_PING_TIMEOUT_MS=3000
# Compose profiles let us skip starting the internal proxy when reusing an
# external one. Leave this set to "internal-traefik" while
# USE_INTERNAL_TRAEFIK=true, otherwise clear the value.
COMPOSE_PROFILES=internal-traefik

# Domain and TLS
APP_HOST=app.example.com
LE_EMAIL=admin@example.com

# Timezone (e.g., Asia/Dubai, Europe/Copenhagen, America/New_York)
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones for valid values
TZ=UTC

# Admin User (automatically created on first startup if not exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password_here

# JWT Configuration (use long, random strings - generate with: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_here_make_it_long_and_random

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# Optional: Frontend build-time API URL (otherwise app uses /api)
# VITE_API_BASE_URL=https://app.example.com/api
