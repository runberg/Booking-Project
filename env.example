# Database credentials — choose any strong password
POSTGRES_USER=booking
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=booking

# Auth secrets — generate with: openssl rand -base64 32
JWT_SECRET=replace_with_random_secret
JWT_REFRESH_SECRET=replace_with_another_random_secret

# Admin account (created automatically on first startup if it does not exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_after_first_login

# The URL users will use to reach the app (used in email links)
FRONTEND_URL=http://your-server-ip
# CORS origin — should match FRONTEND_URL
CORS_ORIGIN=http://your-server-ip

# Timezone (e.g. Europe/Copenhagen, America/New_York)
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Email / SMTP — leave blank to disable email features
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
